# Alpaca Markets Developer API Credentials
# Sign up at https://alpaca.markets — paper trading API is fine for historical bars.
ALPACA_API_KEY_ID=
ALPACA_SECRET_KEY=
# Use the data endpoint for stocks bars (not the paper trading host).
ALPACA_DATA_URL=https://data.alpaca.markets
# ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2


# Canonical public origin of the app. Used to anchor Supabase confirmation
# email links so they always land on production, never on whatever host
# the sign-up happened to be submitted from (eg. localhost during dev).
# Must NOT have a trailing slash.
NEXT_PUBLIC_SITE_URL=https://trend-scan.vercel.app


# Supabase Project Credentials
# Create a project at https://supabase.com. Project URL + anon key are safe to expose.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Service-role key is server-only. Never expose in client code or commit.
SUPABASE_SERVICE_ROLE_KEY=
